#!/bin/bash

# Function to display the banner
show_banner() {
    # Using a nice Laravel-like red/orange color scheme for the banner
    echo -e "\e[38;5;203m"
    cat << "EOF"
  _     _       _       _ _   
 (_)   | |     | |     (_) |  
  _  __| | __ _| | __ _ _| |_ 
 | |/ _` |/ _` | |/ _` | | __|
 | | (_| | (_| | | (_| | | |_ 
 |_|\__,_|\__,_|_|\__, |_|\__|
                   __/ |      
                  |___/       
EOF
    echo -e "\e[0m"
    echo -e "  \e[1mAutomated Git Workflow CLI\e[0m\n"
}

idal_init() {
    show_banner
    
    if [ -d ".git" ]; then
        echo -e "[\e[33mWARNING\e[0m] Already a Git repo. Aborting."
        exit 1
    fi

    echo -e "[\e[34mINFO\e[0m] Initializing project..."
    
    git init -q
    git add .
    git commit -q -m "Commit"
    COMMIT_HASH=$(git rev-parse --short HEAD)
    echo -e "  \e[38;5;214m✦\e[0m Init commit: \e[1;33m$COMMIT_HASH\e[0m"
    
    echo ""
    read -p "Enter origin URL: " repo_url
    
    if [ -z "$repo_url" ]; then
        echo -e "[\e[31mERROR\e[0m] URL empty. Aborting."
        exit 1
    fi
    
    git remote add origin "$repo_url"
    git branch -M main
    
    echo -e "[\e[34mINFO\e[0m] Pushing to \e[1;36m$repo_url\e[0m..."
    git push -q -u origin main
    
    if [ $? -eq 0 ]; then
        echo -e "[\e[32mSUCCESS\e[0m] Pushed."
    else
        echo -e "[\e[31mERROR\e[0m] Push failed."
    fi
}

idal_git() {
    show_banner
    
    if [ ! -d ".git" ]; then
        echo -e "[\e[31mERROR\e[0m] Not a Git repo."
        exit 1
    fi
    
    if [ -z "$(git status --porcelain)" ]; then
        echo -e "[\e[33mWARNING\e[0m] No changes."
        exit 0
    fi
    
    echo -e "[\e[34mINFO\e[0m] Staging files..."
    git add .
    
    echo ""
    read -p "Commit message: " commit_message
    
    if [ -z "$commit_message" ]; then
        echo -e "[\e[31mERROR\e[0m] Empty message. Aborting."
        exit 1
    fi
    
    git commit -q -m "$commit_message"
    COMMIT_HASH=$(git rev-parse --short HEAD)
    echo -e "  \e[38;5;214m✦\e[0m Committed: \e[1;33m$COMMIT_HASH\e[0m (\e[3m$commit_message\e[0m)"
    
    echo -e "[\e[34mINFO\e[0m] Pushing..."
    git push -q
    
    if [ $? -eq 0 ]; then
        echo -e "[\e[32mSUCCESS\e[0m] Pushed!"
    else
        echo -e "[\e[31mERROR\e[0m] Push failed."
    fi
}

idal_status() {
    show_banner
    if [ ! -d ".git" ]; then
         echo -e "[\e[31mERROR\e[0m] Not a Git repo."
         exit 1
    fi
    echo -e "[\e[34mINFO\e[0m] Status:\n"
    
    if [ -z "$(git status --porcelain)" ]; then
        echo -e "  \e[32m✔ Clean\e[0m"
    else
        git status --short | while read line; do
            status=${line:0:2}
            file=${line:3}
            if [[ "$status" == *"M"* ]]; then
                 echo -e "  \e[33m~ Modified\e[0m : $file"
            elif [[ "$status" == *"A"* ]] || [[ "$status" == "??"* ]]; then
                 echo -e "  \e[32m+ Added\e[0m    : $file"
            elif [[ "$status" == *"D"* ]]; then
                 echo -e "  \e[31m- Deleted\e[0m  : $file"
            else
                 echo -e "  \e[90m* $status\e[0m      : $file"
            fi
        done
    fi
    echo ""
}

idal_log() {
    show_banner
    if [ ! -d ".git" ]; then
         echo -e "[\e[31mERROR\e[0m] Not a Git repo."
         exit 1
    fi
    echo -e "[\e[34mINFO\e[0m] Recent Commits:\n"
    
    # Table Header
    printf "\e[1;36m%-10s | %-15s | %-20s | %s\e[0m\n" "Commit" "Date" "Author" "Message"
    echo -e "\e[90m--------------------------------------------------------------------------------------\e[0m"
    
    # Git Log Formatted Output (Reversed so newest is at the bottom)
    git log -n 10 --reverse --date=relative --format="%h|%cd|%an|%s" | while IFS='|' read -r hash date author msg; do
        # Truncate strings to fit standard terminals cleanly
        short_date="${date:0:15}"
        short_author="${author:0:20}"
        
        printf "\e[33m%-10s\e[0m | \e[32m%-15s\e[0m | \e[35m%-20s\e[0m | \e[0m%s\n" "$hash" "$short_date" "$short_author" "$msg"
    done
    
    echo -e "\n"
}

idal_sync() {
    show_banner
    if [ ! -d ".git" ]; then
         echo -e "[\e[31mERROR\e[0m] Not a Git repo."
         exit 1
    fi
    echo -e "[\e[34mINFO\e[0m] Pulling...\n"
    git pull --rebase -q
    if [ $? -eq 0 ]; then
         echo -e "[\e[32mSUCCESS\e[0m] Synced."
    else
         echo -e "[\e[31mERROR\e[0m] Sync failed."
    fi
}

idal_undo() {
    show_banner
    if [ ! -d ".git" ]; then
         echo -e "[\e[31mERROR\e[0m] Not a Git repo."
         exit 1
    fi
    
    # Check if there's a HEAD (at least 1 commit)
    if ! git rev-parse HEAD >/dev/null 2>&1; then
         echo -e "[\e[31mERROR\e[0m] No commits."
         exit 1
    fi

    echo -e "[\e[33mWARNING\e[0m] Undo last commit?"
    echo -e "Keeps files but removes log."
    read -p "Continue? (y/N): " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        git reset --soft HEAD~1
        echo -e "[\e[32mSUCCESS\e[0m] Undone. Files staged."
    else
        echo -e "[\e[34mINFO\e[0m] Cancelled."
    fi
}

idal_help() {
    show_banner
    echo -e "Usage: \e[1;36midal <command>\e[0m\n"
    echo -e "Commands:"
    echo -e "  \e[1;32minit\e[0m    Init repo, commit, and push"
    echo -e "  \e[1;32mgit\e[0m     Stage, commit, and push"
    echo -e "  \e[1;32mstatus\e[0m  Show tree status"
    echo -e "  \e[1;32mlog\e[0m     Show graph tree"
    echo -e "  \e[1;32msync\e[0m    Pull latest safely"
    echo -e "  \e[1;32mundo\e[0m    Undo last commit"
    echo -e "  \e[1;32mhelp\e[0m    Show menu"
    echo ""
}

case "$1" in
    init)
        idal_init
        ;;
    git)
        idal_git
        ;;
    status)
        idal_status
        ;;
    log)
        idal_log
        ;;
    sync)
        idal_sync
        ;;
    undo)
        idal_undo
        ;;
    help|--help|-h|"")
        idal_help
        ;;
    *)
        echo -e "[\e[31mERROR\e[0m] Unknown: $1\n"
        idal_help
        exit 1
        ;;
esac
